export default function PromptRefiner({ phase }: PromptRefinerProps) {
  const [currentStep, setCurrentStep] = useState(0);
  const [blocks, setBlocks] = useState({
    rol: "",
    contexto: "",
    freno: "",
    diagnostico: "",
    accion: "",
    limites: "",
    entrega: "",
  });
  
  const [isGenerating, setIsGenerating] = useState(false);
  const [aiOutput, setAiOutput] = useState<{ optimizedPrompt?: string; result?: string; explanation?: string } | null>(null);
  const [typingText, setTypingText] = useState("");

  const name = phase.name;
  const shortcuts = PHASE_SHORTCUTS[name] || [];
  const templates = PHASE_TEMPLATES[name] || [];

  const handleInputChange = (id: string, value: string) => {
    setBlocks(prev => ({ ...prev, [id]: value }));
  };

  const applyTemplate = (template: any) => {
    if (Object.values(blocks).some(v => v.length > 0)) {
      if (!confirm("¿Deseas sobreescribir el prompt actual con esta plantilla maestra?")) return;
    }
    setBlocks(template.blocks);
    setCurrentStep(0);
  };

  const handleShortcutClick = (shortcut: any) => {
    setBlocks(prev => {
      const currentVal = prev[shortcut.target as keyof typeof prev];
      const shouldAppend = ["contexto", "accion", "diagnostico"].includes(shortcut.target);
      const newVal = shouldAppend && currentVal ? `${currentVal}\n${shortcut.text}` : shortcut.text;
      return { ...prev, [shortcut.target]: newVal };
    });
  };

  const executeAI = async () => {
    setIsGenerating(true);
    setAiOutput(null);
    setTypingText("");

    try {
      const res = await fetch("/api/ai/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          phaseId: phase.id,
          phaseName: phase.name,
          blocks
        })
      });

      const data = await res.json();
      setAiOutput(data);
      
      let i = 0;
      const text = data.result || "";
      const timer = setInterval(() => {
        setTypingText(text.slice(0, i));
        i++;
        if (i > text.length) clearInterval(timer);
      }, 5);
    } catch (err) {
      console.error(err);
    } finally {
      setIsGenerating(false);
    }
  };

  const fullPromptPreview = useMemo(() => {
    return Object.entries(blocks)
      .filter(([_, val]) => val.length > 0)
      .map(([key, val]) => `[${key.toUpperCase()}]\n${val}`)
      .join("\n\n");
  }, [blocks]);

  const currentStepData = STEPS[currentStep] || STEPS[0];
  const currentStepKey = currentStepData.id;
  const relevantShortcuts = shortcuts.filter(s => s.target === currentStepKey);

  return (
    <div className="w-full flex flex-col xl:flex-row gap-8 min-h-[700px]">
      {/* Left side: Form (Wizard) */}
      <div className="flex-1 space-y-6">
        {/* Template Gallery */}
        {templates.length > 0 && (
          <div className="space-y-3 mb-4 animate-in fade-in duration-1000">
             <div className="flex items-center gap-2 px-2">
                <Sparkles className="w-4 h-4 text-primary" />
                <h4 className="text-[10px] font-black text-white/40 uppercase tracking-[0.2em]">Plantillas Maestras ({name})</h4>
             </div>
             <div className="flex gap-3 overflow-x-auto pb-4 custom-scrollbar-horizontal px-2">
                {templates.map((tpl, i) => (
                  <button
                    key={i}
                    onClick={() => applyTemplate(tpl)}
                    className="flex-shrink-0 glass p-4 rounded-2xl border border-primary/20 hover:border-primary transition-all flex items-center gap-3 group bg-primary/5 active:scale-95"
                  >
                    <div className="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center border border-primary/20">
                      <FileCode className="w-4 h-4 text-primary" />
                    </div>
                    <div className="text-left">
                      <p className="text-[10px] font-black text-primary uppercase tracking-tighter">Master Build</p>
                      <p className="text-xs font-bold text-white group-hover:text-primary transition-colors pr-4">{tpl.title}</p>
                    </div>
                  </button>
                ))}
             </div>
          </div>
        )}

        <div className="flex items-center justify-between mb-4 px-2">
          <div className="flex flex-col gap-1 w-full max-w-[400px]">
            <div className="flex justify-between text-[10px] font-black text-primary tracking-widest uppercase mb-1">
              <span>Optimización Estructurada</span>
              <span>{Math.round(((currentStep + 1) / 7) * 100)}%</span>
            </div>
            <div className="flex gap-1.5 h-1.5">
              {STEPS.map((_, idx) => (
                <div 
                  key={idx}
                  className={cn(
                    "flex-1 rounded-full transition-all duration-700",
                    idx <= currentStep ? "bg-primary shadow-[0_0_12px_rgba(0,166,126,0.6)]" : "bg-white/5"
                  )}
                />
              ))}
            </div>
          </div>
        </div>

        <div className="glass p-10 rounded-[3rem] relative overflow-hidden min-h-[500px] border border-white/10 shadow-3xl bg-black/20">
          <AnimatePresence mode="wait">
            <motion.div
              key={currentStep}
              initial={{ opacity: 0, x: 10 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: -10 }}
              transition={{ duration: 0.4 }}
              className="space-y-8 flex flex-col h-full"
            >
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-5">
                  <div className="w-14 h-14 rounded-2xl bg-primary/20 border border-primary/30 flex items-center justify-center shadow-inner">
                    {React.createElement(currentStepData.icon, { className: "w-7 h-7 text-primary" })}
                  </div>
                  <div>
                    <span className="text-[10px] font-bold text-accent uppercase tracking-[0.2em] mb-1 block">Pasaje {currentStep + 1} de 7</span>
                    <h3 className="text-3xl font-black text-white tracking-tighter uppercase">{currentStepData.label}</h3>
                  </div>
                </div>
              </div>

              {/* Shortcuts Grid */}
              {relevantShortcuts.length > 0 && (
                <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
                  {relevantShortcuts.map((shortcut, i) => (
                    <button
                      key={i}
                      onClick={() => handleShortcutClick(shortcut)}
                      className="glass p-3 rounded-2xl border border-white/5 text-left transition-all hover:bg-white/10 hover:border-primary/40 flex items-center gap-3 group active:scale-95"
                    >
                      <div className="w-8 h-8 rounded-xl bg-white/5 flex items-center justify-center border border-white/10 group-hover:bg-primary/20 transition-all flex-shrink-0">
                        {React.createElement(shortcut.icon, { className: "w-4 h-4 text-accent group-hover:text-primary transition-colors" })}
                      </div>
                      <span className="text-[10px] font-bold text-[#D7D3C2]/80 group-hover:text-white leading-tight">{shortcut.label}</span>
                    </button>
                  ))}
                </div>
              )}

              <div className="flex-1 relative group">
                <textarea
                  value={blocks[currentStepKey as keyof typeof blocks]}
                  onChange={(e) => handleInputChange(currentStepKey, e.target.value)}
                  placeholder={currentStepData.placeholder}
                  className="w-full h-full min-h-[220px] bg-black/40 border-2 border-white/5 rounded-3xl p-8 text-lg text-[#F3EFE0] placeholder-white/10 focus:outline-none focus:border-primary/50 transition-all resize-none leading-relaxed font-medium"
                />
                <div className="absolute top-8 right-8 pointer-events-none opacity-[0.03] group-focus-within:opacity-[0.08] transition-opacity">
                   {React.createElement(currentStepData.icon, { className: "w-32 h-32 text-white" })}
                </div>
              </div>
            </motion.div>
          </AnimatePresence>

          <div className="flex justify-between items-center mt-10 pt-8 border-t border-white/10">
            <button
              onClick={() => setCurrentStep(prev => Math.max(0, prev - 1))}
              disabled={currentStep === 0}
              className="px-8 py-3 rounded-2xl text-xs font-black uppercase tracking-widest flex items-center gap-3 hover:bg-white/10 disabled:opacity-30 transition-all text-[#D7D3C2]/60 hover:text-white"
            >
              <ChevronLeft className="w-5 h-5" /> Regresar
            </button>
            
            {currentStep < 6 ? (
              <button
                onClick={() => setCurrentStep(prev => Math.min(6, prev + 1))}
                className="bg-primary hover:bg-[#008f6d] px-10 py-4 rounded-2xl text-xs font-black text-black flex items-center gap-3 transition-all shadow-[0_8px_30px_rgb(0,166,126,0.3)] uppercase tracking-wider"
              >
                Continuar <ChevronRight className="w-5 h-5" />
              </button>
            ) : (
              <button
                onClick={executeAI}
                disabled={isGenerating || !blocks.rol}
                className="bg-primary hover:bg-[#008f6d] px-12 py-4 rounded-2xl text-xs font-black text-black flex items-center gap-3 transition-all shadow-[0_8px_30px_rgb(0,166,126,0.5)] uppercase tracking-wider disabled:opacity-50"
              >
                {isGenerating ? <Loader2 className="w-5 h-5 animate-spin" /> : <BrainCircuit className="w-5 h-5" />}
                REFINAR CON IA
              </button>
            )}
          </div>
        </div>
      </div>

      {/* Right side: Terminal & Explanations */}
      <div className="xl:w-[500px] flex flex-col gap-6">
        <div className="glass rounded-[2.5rem] bg-black border-2 border-primary/20 flex flex-col h-[500px] overflow-hidden shadow-2xl relative">
          <div className="absolute inset-0 pointer-events-none bg-scanline opacity-[0.05] z-10" />
          
          <div className="h-12 bg-white/5 border-b border-white/10 flex items-center justify-between px-6 shrink-0">
            <div className="flex gap-2">
              <div className="w-3 h-3 rounded-full bg-red-500/50" />
              <div className="w-3 h-3 rounded-full bg-yellow-500/50" />
              <div className="w-3 h-3 rounded-full bg-green-500/50" />
            </div>
            <div className="flex items-center gap-2">
              <TerminalIcon className="w-4 h-4 text-primary" />
              <span className="text-[10px] font-black text-[#D7D3C2]/40 uppercase tracking-[0.2em]">PromptRefiner v1.0</span>
            </div>
            <button 
              onClick={() => aiOutput?.optimizedPrompt && navigator.clipboard.writeText(aiOutput.optimizedPrompt)}
              className="text-[10px] text-primary hover:bg-primary/10 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-2 border border-primary/20 font-bold"
            >
              <Copy className="w-3.5 h-3.5" /> COPY PRO
            </button>
          </div>

          <div className="flex-1 p-8 font-mono text-[12px] leading-relaxed overflow-y-auto custom-scrollbar-terminal">
            {isGenerating ? (
              <div className="flex flex-col gap-4 animate-pulse">
                <div className="h-4 bg-primary/20 rounded w-3/4" />
                <div className="h-4 bg-primary/20 rounded w-1/2" />
                <div className="h-4 bg-primary/20 rounded w-5/6" />
                <div className="flex items-center gap-2 mt-4">
                  <Loader2 className="w-4 h-4 animate-spin text-primary" />
                  <span className="text-primary italic">Inyectando mejores prácticas de {name}...</span>
                </div>
              </div>
            ) : aiOutput ? (
              <div className="space-y-6">
                <div>
                  <p className="text-primary font-bold mb-4 flex items-center gap-2">
                    <ChevronRight className="w-4 h-4" /> [PROMPT_OPTIMIZADO_ESTRUCTURADO]
                  </p>
                  <pre className="bg-white/5 p-5 rounded-2xl border border-white/5 whitespace-pre-wrap text-[#D7D3C2]/80 leading-relaxed italic">
                    {aiOutput.optimizedPrompt}
                  </pre>
                </div>
                
                <div>
                  <p className="text-accent font-bold mb-4 flex items-center gap-2">
                    <Terminal className="w-4 h-4" /> [EJECUCIÓN_TÉCNICA_OUTPUT]
                  </p>
                  <div className="text-white whitespace-pre-wrap">
                    <span className="text-primary font-bold mr-2">root@promptcraft:~$</span>
                    {typingText}
                    <span className="inline-block w-2.5 h-5 bg-primary ml-1 animate-pulse" />
                  </div>
                </div>
              </div>
            ) : (
              <div className="h-full flex flex-col items-center justify-center text-center opacity-20">
                <Command className="w-16 h-16 mb-4" />
                <p className="text-sm font-bold uppercase tracking-widest">Esperando Transmisión Estructurada</p>
                <p className="text-[10px] mt-2">Completa los 7 pasos o carga una Master Template</p>
              </div>
            )}
          </div>
        </div>

        <AnimatePresence>
          {aiOutput?.explanation && (
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              className="glass p-8 rounded-[2.5rem] border-2 border-accent/20 bg-accent/5 shadow-xl"
            >
              <div className="flex items-center gap-3 mb-4">
                <BrainCircuit className="w-5 h-5 text-accent" />
                <h4 className="text-xs font-black text-white uppercase tracking-[0.2em]">Explicación Técnica</h4>
              </div>
              <p className="text-sm text-[#D7D3C2]/80 leading-relaxed italic border-l-4 border-accent/30 pl-6">
                {aiOutput.explanation}
              </p>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
}
