"use client";

import React, { useState, useMemo } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { 
  User, 
  Info, 
  TriangleAlert, 
  Stethoscope, 
  PlayCircle, 
  ShieldAlert, 
  Send,
  Zap,
  Terminal as TerminalIcon,
  Copy,
  ChevronRight,
  ChevronLeft,
  Loader2,
  Sparkles,
  Briefcase,
  Code,
  Palette,
  Workflow,
  Cpu,
  Moon,
  Database,
  Search,
  Layout,
  Terminal
} from "lucide-react";
import { clsx, type ClassValue } from "clsx";
import { twMerge } from "tailwind-merge";

function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}

interface PromptLabProps {
  phase: any;
}

const STEPS = [
  { id: "rol", label: "Rol", icon: User, placeholder: "Ej: Senior Software Architect especializado en..." },
  { id: "contexto", label: "Contexto", icon: Info, placeholder: "Ej: Estamos migrando un monorepo a microservicios..." },
  { id: "freno", label: "Freno", icon: TriangleAlert, placeholder: "Ej: No podemos usar Redis por latencia..." },
  { id: "diagnostico", label: "Diagnóstico", icon: Stethoscope, placeholder: "Ej: El sistema actual tiene cuellos de botella en..." },
  { id: "accion", label: "Acción", icon: PlayCircle, placeholder: "Ej: Diseña el esquema de eventos..." },
  { id: "limites", label: "Límites", icon: ShieldAlert, placeholder: "Ej: El código debe ser compatible con Node 18..." },
  { id: "entrega", label: "Entrega", icon: Send, placeholder: "Ej: Formato Markdown con diagramas Mermaid..." },
];

const PHASE_SHORTCUTS: Record<string, { label: string; text: string; target: string; icon: any }[]> = {
  "Requerimientos": [
    { label: "Analista de Negocio", text: "Senior Business Analyst con enfoque en metodologías ágiles...", target: "rol", icon: Briefcase },
    { label: "Historias de Usuario", text: "Escribe historias de usuario siguiendo el formato Estándar (Como/Quiero/Para)...", target: "contexto", icon: Workflow },
    { label: "Definir MVP", text: "Prioriza las funcionalidades esenciales para un Producto Mínimo Viable...", target: "accion", icon: Zap },
  ],
  "Análisis": [
    { label: "Arquitecto Cloud", text: "Arquitecto de Soluciones Cloud especializado en AWS...", target: "rol", icon: Cpu },
    { label: "Análisis de Riesgos", text: "Realiza una matriz de riesgos técnicos (Probabilidad vs Impacto)...", target: "accion", icon: ShieldAlert },
  ],
  "Modelado de Base de Datos": [
    { label: "DBA Senior", text: "Administrador de Base de Datos experto en optimización de queries SQL...", target: "rol", icon: Database },
    { label: "Esquema ERD", text: "Diseña un diagrama Entidad-Relación normalizado...", target: "accion", icon: Workflow },
  ],
  "Diseño de Interfaz": [
    { label: "UI Designer", text: "Diseñador de Interfaz especializado en sistemas de diseño modernos...", target: "rol", icon: Palette },
    { label: "Dark Mode", text: "Aplica una paleta de colores optimizada para temas oscuros premium...", target: "contexto", icon: Moon },
    { label: "Diseño Atómico", text: "Estructura los componentes siguiendo la metodología Atomic Design...", target: "accion", icon: Layout },
  ],
  "Implementación": [
    { label: "Fullstack Eng.", text: "Ingeniero Fullstack experto en Next.js y TypeScript...", target: "rol", icon: Terminal },
    { label: "Tests Unitarios", text: "Asegura una cobertura de tests del 80% usando Vitest...", target: "limites", icon: Code },
  ],
};

const PHASE_REQUIREMENTS: Record<string, { label: string; text: string; target: "contexto" | "accion" }[]> = {
  "Requerimientos": [
    { label: "Incluir Criterios de Aceptación", text: "Asegúrate de definir criterios de aceptación claros para cada historia.", target: "accion" },
    { label: "Definir Actor Principal", text: "Identifica claramente quién es el actor principal del flujo.", target: "contexto" },
    { label: "Flujo Alternativo", text: "Considera qué sucede cuando el usuario cancela el proceso.", target: "accion" },
  ],
  "Análisis": [
    { label: "Análisis de Viabilidad", text: "Evalúa si la solución es técnicamente viable con el stack actual.", target: "contexto" },
    { label: "Matriz de Riesgos", text: "Identifica los 3 riesgos más críticos del requerimiento.", target: "accion" },
  ],
  "Modelado de Base de Datos": [
    { label: "Normalización 3FN", text: "El esquema debe cumplir con la Tercera Forma Normal.", target: "limites" } as any,
    { label: "Índices Críticos", text: "Propón índices para optimizar las consultas de lectura.", target: "accion" },
  ],
  "Diseño de Interfaz": [
    { label: "Accesibilidad WCAG", text: "Garantiza un contraste mínimo AA para el texto.", target: "limites" } as any,
    { label: "Micro-interacciones", text: "Describe el feedback visual al hacer hover en los botones.", target: "accion" },
  ],
};

export default function PromptLab({ phase }: PromptLabProps) {
  const [currentStep, setCurrentStep] = useState(0);
  const [blocks, setBlocks] = useState({
    rol: "",
    contexto: "",
    freno: "",
    diagnostico: "",
    accion: "",
    limites: "",
    entrega: "",
  });
  
  const [isGenerating, setIsGenerating] = useState(false);
  const [aiOutput, setAiOutput] = useState<{ optimizedPrompt?: string; result?: string } | null>(null);
  const [typingText, setTypingText] = useState("");

  const name = phase.name;
  const adaptiveRequirements = PHASE_REQUIREMENTS[name] || [];
  const shortcuts = PHASE_SHORTCUTS[name] || [];

  const handleInputChange = (id: string, value: string) => {
    setBlocks(prev => ({ ...prev, [id]: value }));
  };

  const handleShortcutClick = (shortcut: any) => {
    setBlocks(prev => {
      const currentVal = prev[shortcut.target as keyof typeof prev];
      // Append for context/action, replace for others
      const shouldAppend = ["contexto", "accion", "diagnostico"].includes(shortcut.target);
      const newVal = shouldAppend && currentVal ? `${currentVal}\n${shortcut.text}` : shortcut.text;
      return { ...prev, [shortcut.target]: newVal };
    });
  };

  const handleCheckboxChange = (req: any, checked: boolean) => {
    if (checked) {
      setBlocks(prev => ({
        ...prev,
        [req.target]: prev[req.target as keyof typeof prev] 
          ? `${prev[req.target as keyof typeof prev]}\n${req.text}` 
          : req.text
      }));
    }
  };

  const executeAI = async () => {
    setIsGenerating(true);
    setAiOutput(null);
    setTypingText("");

    try {
      const res = await fetch("/api/ai/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          phaseId: phase.id,
          phaseName: phase.name,
          blocks
        })
      });

      const data = await res.json();
      setAiOutput(data);
      
      let i = 0;
      const text = data.result || "";
      const timer = setInterval(() => {
        setTypingText(text.slice(0, i));
        i++;
        if (i > text.length) clearInterval(timer);
      }, 5);
    } catch (err) {
      console.error(err);
    } finally {
      setIsGenerating(false);
    }
  };

  const fullPromptPreview = useMemo(() => {
    return Object.entries(blocks)
      .filter(([_, val]) => val.length > 0)
      .map(([key, val]) => `[${key.toUpperCase()}]\n${val}`)
      .join("\n\n");
  }, [blocks]);

  const currentStepKey = STEPS[currentStep].id;
  const relevantShortcuts = shortcuts.filter(s => s.target === currentStepKey);

  return (
    <div className="w-full flex flex-col lg:flex-row gap-8 min-h-[600px]">
      {/* Left side: Form */}
      <div className="flex-1 space-y-6">
        <div className="flex items-center justify-between mb-2">
          <div className="flex gap-1">
            {STEPS.map((step, idx) => (
              <div 
                key={idx}
                className={cn(
                  "h-1.5 w-full rounded-full transition-all duration-500",
                  idx <= currentStep ? "bg-primary shadow-[0_0_8px_rgba(0,166,126,0.5)]" : "bg-white/10"
                )}
                title={step.label}
              />
            ))}
          </div>
          <span className="text-[10px] font-bold text-primary uppercase tracking-widest ml-4 min-w-[70px]">
             STEP {currentStep + 1}/7
          </span>
        </div>

        <div className="glass p-8 rounded-[2.5rem] relative overflow-hidden min-h-[450px] border border-white/5 shadow-2xl flex flex-col">
          <AnimatePresence mode="wait">
            <motion.div
              key={currentStep}
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -10 }}
              transition={{ duration: 0.3 }}
              className="space-y-6 flex-1"
            >
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-4">
                  <div className="w-12 h-12 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center">
                    {React.createElement(STEPS[currentStep].icon, { className: "w-6 h-6 text-primary" })}
                  </div>
                  <div>
                    <h3 className="text-xl font-bold text-white tracking-tight">{STEPS[currentStep].label}</h3>
                    <p className="text-xs text-[#D7D3C2]/50 font-medium">Bloque estructural para tu prompt.</p>
                  </div>
                </div>
              </div>

              {/* Shortcuts Grid */}
              <AnimatePresence>
                {relevantShortcuts.length > 0 && (
                  <motion.div 
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: 'auto' }}
                    exit={{ opacity: 0, height: 0 }}
                    className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3"
                  >
                    {relevantShortcuts.map((shortcut, i) => (
                      <motion.button
                        key={i}
                        whileHover={{ y: -2, backgroundColor: "rgba(255, 255, 255, 0.08)" }}
                        whileTap={{ scale: 0.98 }}
                        onClick={() => handleShortcutClick(shortcut)}
                        className="glass p-3 rounded-xl border border-white/5 text-left transition-colors flex items-center gap-3 group"
                      >
                        <div className="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-primary/30">
                          {React.createElement(shortcut.icon, { className: "w-4 h-4 text-accent group-hover:text-primary transition-colors" })}
                        </div>
                        <span className="text-[11px] font-bold text-[#D7D3C2]/80 group-hover:text-white">{shortcut.label}</span>
                      </motion.button>
                    ))}
                  </motion.div>
                )}
              </AnimatePresence>

              <div className="relative group">
                <textarea
                  value={blocks[currentStepKey as keyof typeof blocks]}
                  onChange={(e) => handleInputChange(currentStepKey, e.target.value)}
                  placeholder={STEPS[currentStep].placeholder}
                  className="w-full h-40 bg-white/5 border border-white/10 rounded-2xl p-6 text-white placeholder-white/20 focus:outline-none focus:border-primary/50 transition-colors resize-none text-sm leading-relaxed"
                />
                <div className="absolute bottom-4 right-4 pointer-events-none opacity-20 group-focus-within:opacity-40 transition-opacity">
                   {React.createElement(STEPS[currentStep].icon, { className: "w-8 h-8 text-primary" })}
                </div>
              </div>

              {currentStep === 4 && adaptiveRequirements.length > 0 && (
                <div className="space-y-3 animate-in fade-in slide-in-from-bottom-2 duration-500">
                  <p className="text-[10px] font-bold text-accent uppercase tracking-widest flex items-center gap-2">
                    <Zap className="w-3 h-3" /> Requerimientos Extra ({name})
                  </p>
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-2">
                    {adaptiveRequirements.map((req, i) => (
                      <label key={i} className="flex items-center gap-3 p-3 rounded-xl bg-white/5 border border-white/5 cursor-pointer hover:bg-white/10 transition-colors group">
                        <input 
                          type="checkbox" 
                          onChange={(e) => handleCheckboxChange(req, e.target.checked)}
                          className="w-4 h-4 rounded border-white/20 bg-transparent text-primary focus:ring-primary focus:ring-offset-0"
                        />
                        <span className="text-xs text-[#D7D3C2]/70 group-hover:text-white transition-colors">{req.label}</span>
                      </label>
                    ))}
                  </div>
                </div>
              )}
            </motion.div>
          </AnimatePresence>

          <div className="flex justify-between items-center mt-8 pt-8 border-t border-white/5">
            <button
              onClick={() => setCurrentStep(prev => Math.max(0, prev - 1))}
              disabled={currentStep === 0}
              className="px-6 py-2 rounded-xl text-sm font-bold flex items-center gap-2 hover:bg-white/5 disabled:opacity-20 transition-all text-[#D7D3C2]/60 hover:text-white"
            >
              <ChevronLeft className="w-4 h-4" /> Anterior
            </button>
            
            {currentStep < 6 ? (
              <button
                onClick={() => setCurrentStep(prev => Math.min(6, prev + 1))}
                className="bg-primary hover:bg-primary-dark px-8 py-3 rounded-xl text-sm font-bold text-black flex items-center gap-2 transition-all shadow-lg shadow-primary/20"
              >
                Siguiente <ChevronRight className="w-4 h-4" />
              </button>
            ) : (
              <button
                onClick={executeAI}
                disabled={isGenerating || !blocks.rol}
                className="bg-primary hover:bg-primary-dark px-8 py-3 rounded-xl text-sm font-black text-black flex items-center gap-2 transition-all shadow-lg shadow-primary/40 disabled:opacity-50"
              >
                {isGenerating ? <Loader2 className="w-4 h-4 animate-spin" /> : <Sparkles className="w-4 h-4" />}
                EJECUTAR CON IA
              </button>
            )}
          </div>
        </div>
      </div>

      {/* Right side: Preview & Terminal */}
      <div className="lg:w-[450px] space-y-6">
        <div className="glass rounded-[2rem] p-6 border border-white/5 flex flex-col h-full overflow-hidden">
          <div className="flex items-center justify-between mb-4 px-2">
            <h4 className="text-[10px] font-black text-primary uppercase tracking-[0.2em] flex items-center gap-2">
              <Sparkles className="w-3 h-3" /> Live Preview
            </h4>
            <button 
              onClick={() => navigator.clipboard.writeText(fullPromptPreview)}
              className="text-[10px] text-[#D7D3C2]/50 hover:text-white transition-colors flex items-center gap-1"
            >
              <Copy className="w-3 h-3" /> COPIAR
            </button>
          </div>
          
          <div className="flex-1 bg-black/40 rounded-xl p-6 font-mono text-[11px] leading-relaxed text-[#D7D3C2]/80 overflow-y-auto max-h-[250px] border border-white/5 custom-scrollbar">
            {fullPromptPreview || "// Comienza a escribir para ver la estructura aquí..."}
          </div>

          <div className="mt-6 flex flex-col flex-1 min-h-[350px]">
            <div className="flex items-center gap-2 mb-3 px-2">
              <TerminalIcon className="w-3 h-3 text-accent" />
              <h4 className="text-[10px] font-black text-accent uppercase tracking-[0.2em]">AI TERMINAL</h4>
            </div>
            
            <div className="flex-1 bg-black rounded-xl p-6 font-mono text-[11px] text-primary border border-primary/20 overflow-y-auto max-h-[350px] custom-scrollbar shadow-[inset_0_0_20px_rgba(0,166,126,0.1)]">
              {isGenerating ? (
                <div className="flex items-center gap-2 animate-pulse">
                  <span className="w-2 h-2 rounded-full bg-primary" />
                  Generando resultado técnico...
                </div>
              ) : aiOutput ? (
                <div className="space-y-4">
                  <div className="p-3 bg-primary/10 rounded-lg border border-primary/20 mb-4 animate-in fade-in duration-500">
                     <p className="text-[9px] font-bold text-primary mb-2 tracking-widest underline decoration-wavy">PROMPT OPTIMIZADO POR EXPERTO</p>
                     <p className="italic text-[#D7D3C2]/60 whitespace-pre-wrap">{aiOutput.optimizedPrompt}</p>
                  </div>
                  <div className="whitespace-pre-wrap text-white">
                    <span className="text-secondary font-bold mr-2 text-primary">promptcraft@academy:~$</span>
                    {typingText}
                    <span className="inline-block w-2 h-4 bg-primary ml-1 animate-pulse" />
                  </div>
                </div>
              ) : (
                <div className="opacity-30">Esperando ejecución estructurada...</div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
