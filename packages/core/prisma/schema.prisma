// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  fullName         String   @map("full_name")
  avatarUrl        String?  @map("avatar_url")
  role             String   @default("APODERADO")
  forgedRole       String?  @map("forged_role")
  forgedStack      String?  @map("forged_stack")
  forgedPattern    String?  @default("AgentX") @map("forged_pattern")
  forgedMethodology String? @map("forged_methodology")
  hasForgedIdentity Boolean @default(false) @map("has_forged_identity")
  uiPreferences    String   @default("{\"theme\": \"dark\", \"dashboard_view\": \"summary\", \"glassmorphism\": false}") @map("ui_preferences")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  projects   Project[]
  logs       ExecutionLog[]
  milestones Milestone[]

  @@map("profiles")
}

model SdlcPhase {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  categories Category[]

  @@map("sdlc_phases")
}

model Category {
  id          String     @id @default(uuid())
  phaseId     String     @map("phase_id")
  phase       SdlcPhase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  templates PromptTemplate[]

  @@map("categories")
}

model Project {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  templates PromptTemplate[]

  @@map("projects")
}

model PromptTemplate {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  categoryId     String?  @map("category_id")
  category       Category? @relation(fields: [categoryId], references: [id])
  title          String
  currentVersion Int      @default(1) @map("current_version")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  versions PromptVersion[]

  @@map("prompt_templates")
}

model PromptVersion {
  id            String   @id @default(uuid())
  promptId      String   @map("prompt_id")
  prompt        PromptTemplate @relation(fields: [promptId], references: [id], onDelete: Cascade)
  versionNumber Int      @map("version_number")
  content       String
  aiConfig      String     @map("ai_config")
  changeSummary String?  @map("change_summary")
  createdAt     DateTime @default(now()) @map("created_at")

  logs ExecutionLog[]

  @@map("prompt_versions")
}

model ExecutionLog {
  id              String        @id @default(uuid())
  promptVersionId String        @map("prompt_version_id")
  promptVersion   PromptVersion @relation(fields: [promptVersionId], references: [id])
  userId          String        @map("user_id")
  user            Profile       @relation(fields: [userId], references: [id])
  inputData       String?         @map("input_data")
  outputResponse  String?       @map("output_response")
  latencyMs       Int?          @map("latency_ms")
  tokenUsage      String?       @map("token_usage")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@map("execution_logs")
}

model AppConfig {
  id             String   @id @default("global_config")
  isGlobalPaused Boolean  @default(false) @map("is_global_paused")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

model Milestone {
  id            String   @id @default(uuid())
  profileId     String   @map("profile_id")
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title         String
  body          String   @db.Text
  targetRoute   String   @map("target_route")
  isCompleted   Boolean  @default(false) @map("is_completed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("milestones")
}
