{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "pnpm --filter web build",
  "installCommand": "pnpm install",
  "outputDirectory": "apps/web/.next",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/copilotkit",
      "destination": "/api/copilotkit"
    }
  ]
}
