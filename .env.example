# Database Configuration (PostgreSQL recommended for Vercel)
DATABASE_URL="postgresql://user:password@localhost:5432/promptcraft"

# AI Configuration (Google Gemini)
GOOGLE_API_KEY="your-google-ai-api-key"

# Authentication (NextAuth)
NEXTAUTH_SECRET="generate-a-long-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Feature Flags & System Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
IS_GLOBAL_PAUSED="false"

# UI Preferences (JSON String)
DEFAULT_UI_PREFERENCES='{"theme": "dark", "dashboard_view": "summary", "glassmorphism": true}'
